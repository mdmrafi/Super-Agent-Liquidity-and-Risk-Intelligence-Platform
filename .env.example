# Copy to .env and fill in real values. .env is gitignored -- never commit it.

# Used by backend/chat/answer.py for the Stage 6 assistant's real LLM calls.
OPENAI_API_KEY=

# Backend (FastAPI/uvicorn) and frontend (Vite) dev-server ports. Both
# backend/api/main.py and frontend/vite.config.js read these -- change here,
# not in code, if the defaults collide with something else on your machine.
BACKEND_PORT=8000
FRONTEND_PORT=5173

# MongoDB Atlas connection string + database name (mock users + migrated
# transaction ledger). See backend/db/.
MONGODB_URI=
MONGODB_DB_NAME=Super_agent

# Signs login JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
